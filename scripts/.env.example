PUSH_TOKEN=replace-with-railway-PUSH_TOKEN
PUSH_URL=https://davinomjr.com/investments/api/portfolio/import-push
IBKR_TRIGGER_URL=https://davinomjr.com/investments/api/portfolio/import-ibkr-trigger
# Headless triggers Cloudflare on the B3 portal — keep false so a real
# Chromium window pops up in the GUI session and clears Cloudflare visually.
# The launchd plist must be a LaunchAgent (runs in user session) for this.
HEADLESS=false
# Enable silent re-login when B3 session expires. Without these, the daily
# sync stops at the first session expiration until you manually run
# `python -m app.main login`. Auto-login does NOT handle 2FA prompts.
B3_CPF=
B3_PASSWORD=
